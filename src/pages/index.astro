---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Kwesi Afriyie | Personal Blog';
const description = 'crazy about technology & a student.';
const permalink = Astro.site.href;
const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description} permalink={permalink}>
  <div class="home-container">
    <div class="home-copy">
      <h1>Welcome to my digital garden</h1>
      <p>
        Ughh, i’ve never been a big fan of rigid professional titles, but if i had to summarize it: i’m a software engineer, a technology consultant, and a lifelong student.
      </p>
      <p class="sub-copy">
        This journal is my dedicated space for documenting life experiences, complex technical troubleshooting fixes, exploring IT strategy, and sharing reflections on balancing high-stakes professional consulting alongside rigorous academic milestones.
      </p>
    </div>

    <div class="hero-image-container">
      <picture>
        <source srcset={`${baseUrl}assets/home-illustration.webp`} media="(min-width: 600px)">
        <img class="hero-image" alt="Illustration of person reading a book" src={`${baseUrl}assets/home-illustration-small.webp`} width="550" height="466">
      </picture>
      <p class="caption">
        Illustration by
        <a href="https://icons8.com/illustrations/author/5c07e68d82bcbc0092519bb6" target="_blank" rel="noopener">Icons 8</a>
        from
        <a href="https://icons8.com/illustrations" target="_blank" rel="noopener">Ouch!</a>
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .home-container {
    align-items: center;
    display: flex;
    flex: 1;
    justify-content: center;
    margin: 2em 0;
    min-height: 400px;
  }

  .home-copy {
    flex: 1;
    padding: 0 1em;
  }

  .home-copy h1 {
    font-weight: 700;
    margin-bottom: 0.5em;
    line-height: 1.2;
    font-size: 2.8em;
  }

  .home-copy p {
    font-size: 1.3em;
    line-height: 1.6;
    margin-bottom: 0.8em;
  }

  .home-copy .sub-copy {
    font-size: 1.1em;
    color: var(--text-secondary, #666);
    line-height: 1.5;
  }

  :global(.dark) .home-copy .sub-copy {
    color: #a0aec0;
  }

  .hero-image-container {
    margin: 0 1em;
    text-align: center;
  }

  .hero-image-container picture {
    display: block;
    min-height: 250px;
  }

  .caption {
    font-size: .8em;
    font-style: italic;
    text-align: left;
  }

  .hero-image {
    width: 100%;
    max-width: 550px;
    margin-bottom: 1em;
  }

  @media (max-width: 1200px) {
    .home-copy h1 {
      font-size: 2.3em;
    }
    .home-copy p {
      font-size: 1.15em;
    }
    .home-copy .sub-copy {
      font-size: 1rem;
    }
    .hero-image {
      max-width: 400px;
    }
  }

  @media (max-width: 800px) {
    .home-container {
      flex-direction: column;
    }

    .home-copy {
      flex: 0;
      padding-bottom: 2em;
      text-align: center;
    }
    
    .caption {
      text-align: center;
    }
  }
</style>