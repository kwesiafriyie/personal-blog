---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'About Me';
const description = 'Learn more about my professional journey, academic pursuits, and expertise.';
const permalink = `${Astro.site.href}about`;
const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description} permalink={permalink} current="about">
  <div class="container">
    <h1>About Me</h1>
    
    <!-- <figure class="about-image">
      <img src={`${baseUrl}assets/about-illustration.webp`} alt="Illustration of workspace layout" width="330">
      <figcaption>
        Illustration by
        <a href="https://icons8.com/illustrations/author/5c07e68d82bcbc0092519bb6" target="_blank" rel="noopener">Icons 8</a>
        from
        <a href="https://icons8.com/illustrations" target="_blank" rel="noopener">Ouch!</a>
      </figcaption>
    </figure> -->

    <p class="intro-text">
      Hello! i am a software engineer & technology consultant passionate about bridging the gap between complex engineering systems, payments and corporate business strategies. i focus on optimizing software infrastructure, testing, designing digital workflows, and helping enterprises scale through smart tech integrations.
    </p>

    <h2>Academic Foundation</h2>
    <p>
      To complement my hands-on industry experience, i am currently pursuing an MSc. This advanced degree allows me to research enterprise information frameworks, data governance models, and corporate systems architecture, instantly applying these theoretical insights to real-world corporate challenges.
    </p>

    <h2>What I Do</h2>
    <ul>
      <li><strong>IT Consulting & Strategy:</strong> Helping businesses modernize their operations by evaluating legacy tech stacks and managing high-stakes cloud transformations and payments.</li>
      <li><strong>Enterprise Integrations:</strong> Designing unified communication structures and data schemas that keep business verticals synchronized.</li>
      <li><strong>Workflow Automation:</strong> Building customized operational pipelines that eliminate human bottlenecks and cut down operational overhead.</li>
    </ul>

    <h2>About This Journal</h2>
    <p>
      This digital garden serves as an interactive scratchpad and reflection journal. Here, I document deep technical troubleshooting fixes, summarize strategic consulting takeaways, and write about the daily mechanics of balancing rigorous higher education milestones with a fast-paced professional engineering career.
    </p>

    <p>
      Want to exchange ideas on systems implementation, consult on an enterprise architecture strategy, or just connect over tech culture? Reach out—I am always open to compelling professional collaborations.
    </p>
  </div>
</BaseLayout>

<style>
  .intro-text {
    font-size: 1.15rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  h2 {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  ul {
    margin-bottom: 1.5rem;
    padding-left: 1.25rem;
  }

  li {
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .about-image {
    float: right;
    margin: -1em -4em 2em 2em;
    max-width: 300px;
  }

  .about-image img {
    border-radius: 8px;
    margin-bottom: 0.5em;
  }

  @media (max-width: 1020px) {
    .about-image {
      float: none;
      margin: 0 auto 2em;
      text-align: center;
    }
  }
</style>